{
    "custom/arch": {
        "format": "ґ░гЗ",
        "tooltip": true,
        "tooltip-format": "btw"
    },


    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "format-icons": {
            "urgent": "яБк",
            "active": "яЖТ",
            "default": "яДС"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon} {volume}% яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "яЗл   {essid} ({signalStrength}%)",
        "format-ethernet": "{ipaddr}/{cidr} яЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "Disconnected тЪа",
	"on-click": "sh ~/scripts/rofi-wifi-menu/rofi-wifi-menu.sh"
	 
    },
    "cpu": {
        "format": "яЛЫ  {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "яГЙ  {}%",
	"tooltip": true
    },
    "temperature": {
        "interval": 10,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
        "critical-threshold": 85,
        "format-critical": "яЛЗ {temperatureC}",
        "format": "яЛЙ {temperatureC}┬░C"
    },
    "hyprland/language": {
       "format": "яВм  {}",
       "format-en": "EN",
       "format-ru": "RU"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "яЧз  {capacity}%",
        "format-plugged": "яЗж  {capacity}%",
        "format-alt": "{time}  {icon}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
        "format": "{:%H:%M | %e %B} ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "custom/obs":{
        "format": "{}",
        "tooltip": true,
        "exec": "~/.local/bin/bar/obs.py",
        "return-type": "json",
        "interval": 1
    },
"mpris": {
	"format": "DEFAULT: {player_icon} {dynamic}",
	"format-paused": "DEFAULT: {status_icon} <i>{dynamic}</i>",
	"player-icons": {
		"default": "тЦ╢",
		"mpv": "ЁЯО╡"
	},
	"status-icons": {
		"paused": "тП╕"
	},
	// "ignored-players": ["firefox"]
}
}
